# ============================================================================
# Quantos environment — copy to .env (functions) / set in Netlify env.
# Never commit real secrets. Service-role key is SERVER-ONLY (Netlify Functions).
#
# The FRONTEND Supabase URL + anon key are set directly in apps/index.html
# (look for the SUPABASE_URL / SUPABASE_ANON_KEY constants) — the anon key is
# safe in the browser because RLS enforces tenancy.
# ============================================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=                 # safe for the browser (RLS enforces tenancy)
SUPABASE_SERVICE_ROLE_KEY=         # SERVER ONLY — bypasses RLS; never ship to browser

# --- Stripe (billing is stubbed until these are filled) ---
STRIPE_SECRET_KEY=                 # SERVER ONLY
STRIPE_WEBHOOK_SECRET=             # SERVER ONLY — from `stripe listen` / dashboard
STRIPE_PUBLISHABLE_KEY=

# Price IDs — create products/prices in Stripe, then paste the price IDs here.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# --- App ---
APP_URL=http://localhost:8888      # used for Stripe success/cancel redirects
